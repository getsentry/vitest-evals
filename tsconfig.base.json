{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "vitest-evals": ["packages/vitest-evals/src/index.ts"],
      "vitest-evals/*": ["packages/vitest-evals/src/*"],
      "@vitest-evals/harness-ai-sdk": ["packages/harness-ai-sdk/src/index.ts"],
      "@vitest-evals/harness-openai-agents": [
        "packages/harness-openai-agents/src/index.ts"
      ],
      "@vitest-evals/harness-pi-ai": ["packages/harness-pi-ai/src/index.ts"],
      "@vitest-evals/github-reporter": [
        "packages/github-reporter/src/index.ts"
      ],
      "@vitest-evals/core": ["packages/core/src/index.ts"],
      "@vitest-evals/core/node": ["packages/core/src/node.ts"],
      "@vitest-evals/report-ui": ["packages/report-ui/src/index.ts"]
    }
  }
}
