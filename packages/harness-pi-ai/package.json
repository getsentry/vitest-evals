{
  "name": "@vitest-evals/harness-pi-ai",
  "version": "0.9.0",
  "description": "pi-ai harness adapter with tool replay for vitest-evals.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/vitest-evals.git",
    "directory": "packages/harness-pi-ai"
  },
