{
  "name": "vitest-evals",
  "version": "0.9.0-beta.2",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./judges": {
      "source": "./src/judges/index.ts",
      "types": "./dist/judges/index.d.ts",
      "require": "./dist/judges/index.js",
      "import": "./dist/judges/index.mjs"
    },
    "./legacy": {
      "source": "./src/legacy.ts",
      "types": "./dist/legacy.d.ts",
      "require": "./dist/legacy.js",
      "import": "./dist/legacy.mjs"
    },
    "./harness": {
      "source": "./src/harness.ts",
      "types": "./dist/harness.d.ts",
      "require": "./dist/harness.js",
      "import": "./dist/harness.mjs"
    },
    "./replay": {
      "source": "./src/replay.ts",
      "types": "./dist/replay.d.ts",
      "require": "./dist/replay.js",
      "import": "./dist/replay.mjs"
    },
    "./reporter": {
      "source": "./src/reporter.ts",
      "types": "./dist/reporter.d.ts",
      "require": "./dist/reporter.js",
      "import": "./dist/reporter.mjs"
    }
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts"
  },
  "peerDependencies": {
    "ai": ">=4 <7",
    "tinyrainbow": ">=2 <4",
    "vitest": ">=4 <5",
    "zod": ">=3 <5"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
