---
interface Props {
  links: Array<{ href: string; label: string; level?: number }>;
}

const { links } = Astro.props;
---

<div class="docs-shell">
  <aside class="docs-sidebar" aria-label="Page sections">
    {
      links.map((link) => (
        <a
          href={link.href}
          class:list={{ subsection: (link.level ?? 1) > 1 }}
        >
          {link.label}
        </a>
      ))
    }
  </aside>
  <article class="docs-content">
    <slot />
  </article>
</div>
