---
import { Font } from "astro:assets";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Harness-backed AI testing on top of Vitest." } =
  Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const pageTitle = title === "Home" ? "vitest-evals" : `${title} | vitest-evals`;
const navItems = [
  { href: "/", label: "Overview" },
  { href: "/docs", label: "Guide" },
  { href: "/api", label: "API" },
];

function normalize(path: string) {
  return path.replace(/\/+$/, "") || "/";
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <Font cssVariable="--font-geist-mono" preload />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner container wide">
        <a href={`${base}/`} class="nav-logo" aria-label="vitest-evals home">
          <span>vitest-evals</span>
        </a>
        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span class="hamburger"></span>
        </button>
        <div class="nav-links">
          {
            navItems.map((item) => (
              <a
                href={`${base}${item.href === "/" ? "/" : item.href}`}
                class:list={{ active: normalize(currentPath) === item.href }}
              >
                {item.label}
              </a>
            ))
          }
          <a
            href="https://github.com/getsentry/vitest-evals"
            class="nav-github"
            aria-label="GitHub repository"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2.23c-3.34.73-4.03-1.42-4.03-1.42-.55-1.39-1.33-1.76-1.33-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23A11.5 11.5 0 0 1 12 5.8c1.02 0 2.05.14 3.01.41 2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.69.8.58A12.01 12.01 0 0 0 24 12c0-6.63-5.37-12-12-12Z"></path>
            </svg>
          </a>
        </div>
      </div>
    </nav>

    <main class="container">
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <p>
          Apache-2.0 License ·
          <a href="https://github.com/getsentry/vitest-evals">GitHub</a> ·
          <a href={`${base}/llms.txt`}>llms.txt</a>
        </p>
      </div>
    </footer>

    <script>
      const PM_STORAGE_KEY = "vitest-evals-docs-pm";

      function initNavToggle() {
        const toggle = document.querySelector(".nav-toggle");
        const nav = document.querySelector(".nav");
        if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) {
          return;
        }

        toggle.addEventListener("click", () => {
          const expanded = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!expanded));
          nav.classList.toggle("nav-open");
        });
      }

      function setPackageManager(pm) {
        document.querySelectorAll(".pm-tabs").forEach((container) => {
          container.querySelectorAll(".tab-btn").forEach((button) => {
            button.classList.toggle("active", button.getAttribute("data-pm") === pm);
          });

          container.querySelectorAll(".tab-content").forEach((content) => {
            content.classList.toggle("hidden", content.getAttribute("data-pm") !== pm);
          });
        });
      }

      function initPackageManagerTabs() {
        const savedPm = localStorage.getItem(PM_STORAGE_KEY);
        if (savedPm) {
          setPackageManager(savedPm);
        }

        document.querySelectorAll(".pm-tabs .tab-btn").forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          button.addEventListener("click", () => {
            const pm = button.getAttribute("data-pm");
            if (!pm) {
              return;
            }
            localStorage.setItem(PM_STORAGE_KEY, pm);
            setPackageManager(pm);
          });
        });
      }

      function textForCopy(root) {
        const custom = root.getAttribute("data-copy-text");
        if (custom) {
          return custom;
        }

        const source =
          root.querySelector(".tab-content:not(.hidden)") ??
          root.querySelector(".copy-source") ??
          root;
        return (source.textContent || "")
          .split("\n")
          .map((line) => line.replace(/^\s*[$>]\s*/, ""))
          .join("\n")
          .trim();
      }

      function initCopyButtons() {
        document.querySelectorAll("[data-copy-root]").forEach((root) => {
          const button = root.querySelector(".copy-button");
          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          button.addEventListener("click", async () => {
            try {
              await navigator.clipboard.writeText(textForCopy(root));
              button.classList.add("copied");
              setTimeout(() => button.classList.remove("copied"), 1600);
            } catch {
              button.classList.remove("copied");
            }
          });
        });
      }

      function initSectionNav() {
        const sidebar = document.querySelector(".docs-sidebar");
        if (!(sidebar instanceof HTMLElement)) {
          return;
        }

        const links = Array.from(
          sidebar.querySelectorAll('a[href^="#"]'),
        ).filter((link) => link instanceof HTMLAnchorElement);
        const sections = links
          .map((link) => ({
            link,
            section: document.getElementById(link.hash.slice(1)),
          }))
          .filter(({ section }) => section instanceof HTMLElement);

        if (sections.length === 0) {
          return;
        }

        function setActive(id) {
          links.forEach((link) => {
            const isActive = link.hash === `#${id}`;
            link.classList.toggle("active", isActive);
            if (isActive) {
              link.setAttribute("aria-current", "location");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        }

        if (!("IntersectionObserver" in window)) {
          setActive(sections[0].section.id);
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

            if (visible?.target instanceof HTMLElement) {
              setActive(visible.target.id);
            }
          },
          {
            rootMargin: "-16% 0px -68%",
            threshold: [0.1, 0.35, 0.6],
          },
        );

        sections.forEach(({ section }) => observer.observe(section));
        const initialId = window.location.hash.slice(1) || sections[0].section.id;
        setActive(initialId);
      }

      initNavToggle();
      initPackageManagerTabs();
      initCopyButtons();
      initSectionNav();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
