---
import { Code } from "astro:components";
import DocsPageShell from "../components/DocsPageShell.astro";
import Base from "../layouts/Base.astro";
import apiData from "../generated/api.json";

type TypeDocType = Record<string, any>;
type TypeDocCommentPart = { kind?: string; text?: string };
type TypeDocComment = {
  summary?: TypeDocCommentPart[];
  blockTags?: Array<{
    tag?: string;
    content?: TypeDocCommentPart[];
  }>;
};
type TypeDocReflection = {
  id?: number;
  name: string;
  kind?: number;
  flags?: Record<string, boolean>;
  comment?: TypeDocComment;
  children?: TypeDocReflection[];
  signatures?: TypeDocReflection[];
  parameters?: TypeDocReflection[];
  typeParameters?: TypeDocReflection[];
  indexSignatures?: TypeDocReflection[];
  type?: TypeDocType;
  default?: TypeDocType;
  defaultValue?: string;
};

const KIND_FUNCTION = 64;
const KIND_INTERFACE = 256;

const allEntries = ((apiData as { children?: TypeDocReflection[] }).children ??
  []) as TypeDocReflection[];
const byName = new Map(allEntries.map((entry) => [entry.name, entry]));

const groups = [
  {
    id: "functions",
    label: "Functions",
    names: [
      "describeEval",
      "createHarness",
      "createJudge",
      "StructuredOutputJudge",
      "ToolCallJudge",
      "normalizeHarnessRun",
      "formatScores",
    ],
  },
  {
    id: "suite-types",
    label: "Suite Types",
    names: [
      "DescribeEvalOptions",
      "EvalRun",
      "EvalRunOptions",
      "EvalHarnessRun",
      "EvalTestContext",
      "EvalTestAPI",
      "EvalMatchers",
      "ToSatisfyJudge",
      "JudgeAssertionOptions",
    ],
  },
  {
    id: "harness-types",
    label: "Harness Types",
    names: [
      "Harness",
      "HarnessContext",
      "HarnessRun",
      "HarnessRunError",
      "HarnessMetadata",
      "HarnessResultLike",
      "CreateHarnessOptions",
      "CreateHarnessRunArgs",
      "SimpleHarnessResult",
      "SimpleToolCallRecord",
      "MaybePromise",
    ],
  },
  {
    id: "normalized-data",
    label: "Normalized Data",
    names: [
      "JsonPrimitive",
      "JsonValue",
      "ToolCallRecord",
      "NormalizedMessage",
      "NormalizedSession",
      "UsageSummary",
      "TimingSummary",
    ],
  },
  {
    id: "judge-types",
    label: "Judge Types",
    names: [
      "Judge",
      "JudgeContext",
      "JudgeResult",
      "JudgeOptions",
      "JudgeAssessFn",
      "JudgeAssessor",
      "JudgeAssessorOptions",
      "BoundJudgeAssessor",
      "JudgeAssessWithAssessorFn",
      "ToolCallJudgeConfig",
      "ToolCallJudgeExpectedTool",
      "ToolCallJudgeOptions",
      "StructuredOutputJudgeConfig",
      "StructuredOutputJudgeExpected",
      "StructuredOutputJudgeOptions",
    ],
  },
  {
    id: "matchers-and-helpers",
    label: "Matchers and Helpers",
    names: [
      "BaseMatcherConfig",
      "MatchStrategy",
      "FuzzyMatchOptions",
      "toolCalls",
      "messagesByRole",
      "systemMessages",
      "userMessages",
      "assistantMessages",
      "toolMessages",
      "attachHarnessRunToError",
      "getHarnessRunFromError",
      "wrapText",
    ],
  },
];

const documentedNames = new Set(groups.flatMap((group) => group.names));
const uncategorizedEntries = allEntries
  .filter((entry) => !documentedNames.has(entry.name))
  .sort((a, b) => a.name.localeCompare(b.name));
const renderedGroups =
  uncategorizedEntries.length > 0
    ? [
        ...groups,
        {
          id: "other-exports",
          label: "Other Exports",
          names: uncategorizedEntries.map((entry) => entry.name),
        },
      ]
    : groups;

function slug(name: string) {
  return name
    .replace(/([a-z0-9])([A-Z])/g, "$1-$2")
    .replace(/[^a-zA-Z0-9]+/g, "-")
    .replace(/^-|-$/g, "")
    .toLowerCase();
}

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function stripInlineCodeFence(value: string) {
  return value.replace(/^`|`$/g, "");
}

function commentHtml(comment: TypeDocComment | undefined) {
  const parts = comment?.summary ?? [];
  return parts
    .map((part) => {
      const text = part.text ?? "";
      if (part.kind === "code") {
        return `<code>${escapeHtml(stripInlineCodeFence(text))}</code>`;
      }
      return escapeHtml(text);
    })
    .join("")
    .trim();
}

function commentsFor(entry: TypeDocReflection) {
  return [
    entry.comment,
    ...(entry.signatures ?? []).map((signature) => signature.comment),
  ].filter(Boolean) as TypeDocComment[];
}

function primaryComment(entry: TypeDocReflection) {
  return commentsFor(entry)[0];
}

function examplesFromComment(comment: TypeDocComment | undefined) {
  return (comment?.blockTags ?? [])
    .filter((tag) => tag.tag === "@example")
    .map((tag) =>
      (tag.content ?? [])
        .map((part) => part.text ?? "")
        .join("")
        .replace(/^```[a-z]*\n?/i, "")
        .replace(/\n?```$/i, "")
        .trim(),
    )
    .filter(Boolean);
}

function examples(entry: TypeDocReflection) {
  const seen = new Set<string>();
  return commentsFor(entry)
    .flatMap(examplesFromComment)
    .filter((example) => {
      if (seen.has(example)) {
        return false;
      }
      seen.add(example);
      return true;
    });
}

function typeParameters(params: TypeDocReflection[] | undefined) {
  if (!params?.length) {
    return "";
  }

  return `<${params.map(typeParameter).join(", ")}>`;
}

function typeParameter(param: TypeDocReflection) {
  const constraint = param.type ? ` extends ${typeToString(param.type)}` : "";
  const defaultType = param.default ? ` = ${typeToString(param.default)}` : "";
  return `${param.name}${constraint}${defaultType}`;
}

function parameter(param: TypeDocReflection) {
  const rest = param.flags?.isRest ? "..." : "";
  const optional = param.flags?.isOptional ? "?" : "";
  return `${rest}${param.name}${optional}: ${typeToString(param.type)}`;
}

function parameterName(param: TypeDocReflection) {
  const rest = param.flags?.isRest ? "..." : "";
  const optional = param.flags?.isOptional ? "?" : "";
  return `${rest}${param.name}${optional}`;
}

function signatureReturn(signature: TypeDocReflection) {
  return typeToString(signature.type);
}

function indentBlock(value: string, spaces = 2) {
  const indent = " ".repeat(spaces);
  return value
    .split("\n")
    .map((line) => `${indent}${line}`)
    .join("\n");
}

function parameterBlock(value: string) {
  return indentBlock(`${value},`);
}

function functionSignature(name: string, signature: TypeDocReflection) {
  const params = (signature.parameters ?? []).map(parameter);
  const typeParams = typeParameters(signature.typeParameters);
  const returnType = signatureReturn(signature);

  if (params.length === 0) {
    return `function ${name}${typeParams}(): ${returnType};`;
  }

  return `function ${name}${typeParams}(\n${params
    .map(parameterBlock)
    .join("\n")}\n): ${returnType};`;
}

function functionType(signature: TypeDocReflection) {
  const params = (signature.parameters ?? []).map(parameter);
  const returnType = signatureReturn(signature);

  if (params.length === 0) {
    return `() => ${returnType}`;
  }

  return `(\n${params.map(parameterBlock).join("\n")}\n) => ${returnType}`;
}

function indexSignature(signature: TypeDocReflection) {
  const params = (signature.parameters ?? []).map(parameter).join(", ");
  return `[${params}]: ${typeToString(signature.type)};`;
}

function reflectionObject(declaration: TypeDocReflection) {
  const lines = [
    ...(declaration.indexSignatures ?? []).map(indexSignature),
    ...(declaration.children ?? []).map(memberLine),
  ];

  if (lines.length === 0) {
    return "{}";
  }

  return `{\n${lines.map((line) => indentBlock(line)).join("\n")}\n}`;
}

function memberLine(member: TypeDocReflection) {
  const readonly = member.flags?.isReadonly ? "readonly " : "";
  const optional = member.flags?.isOptional ? "?" : "";
  return `${readonly}${member.name}${optional}: ${typeToString(member.type)};`;
}

function typeToString(type: TypeDocType | undefined): string {
  if (!type) {
    return "void";
  }

  switch (type.type) {
    case "intrinsic":
      return type.name;
    case "literal":
      return JSON.stringify(type.value);
    case "reference": {
      const args = type.typeArguments?.length
        ? `<${type.typeArguments.map(typeToString).join(", ")}>`
        : "";
      return `${type.name ?? "unknown"}${args}`;
    }
    case "array":
      return `${typeToString(type.elementType)}[]`;
    case "tuple":
      return `[${(type.elements ?? []).map(typeToString).join(", ")}]`;
    case "union":
      return (type.types ?? []).map(typeToString).join(" | ");
    case "intersection":
      return (type.types ?? []).map(typeToString).join(" & ");
    case "reflection": {
      const declaration = type.declaration as TypeDocReflection | undefined;
      if (!declaration) {
        return "unknown";
      }
      if (declaration.signatures?.length === 1) {
        return functionType(declaration.signatures[0]);
      }
      if (declaration.signatures?.length) {
        return declaration.signatures.map(functionType).join(" & ");
      }
      return reflectionObject(declaration);
    }
    case "indexedAccess":
      return `${typeToString(type.objectType)}[${typeToString(type.indexType)}]`;
    case "query":
      return `typeof ${typeToString(type.queryType)}`;
    case "rest":
      return `...${typeToString(type.elementType)}`;
    case "optional":
      return `${typeToString(type.elementType)} | undefined`;
    default:
      return type.name ?? type.type ?? "unknown";
  }
}

function declarationKind(entry: TypeDocReflection) {
  if (entry.kind === KIND_FUNCTION || entry.signatures?.length) {
    return "function";
  }
  if (entry.kind === KIND_INTERFACE) {
    return "interface";
  }
  return "type";
}

function declarationCode(entry: TypeDocReflection) {
  if (entry.signatures?.length) {
    return entry.signatures
      .map((signature) => functionSignature(entry.name, signature))
      .join("\n");
  }

  if (entry.kind === KIND_INTERFACE) {
    return `interface ${entry.name}${typeParameters(entry.typeParameters)} ${reflectionObject(entry)}`;
  }

  if (entry.children?.length) {
    return `type ${entry.name}${typeParameters(entry.typeParameters)} = ${reflectionObject(entry)};`;
  }

  return `type ${entry.name}${typeParameters(entry.typeParameters)} = ${typeToString(entry.type)};`;
}

function collectMembersFromType(type: TypeDocType | undefined) {
  if (!type) {
    return [] as TypeDocReflection[];
  }

  if (type.type === "reflection") {
    const declaration = type.declaration as TypeDocReflection | undefined;
    return declaration?.children ?? [];
  }

  if (type.type === "intersection" || type.type === "union") {
    return (type.types ?? []).flatMap(collectMembersFromType);
  }

  return [] as TypeDocReflection[];
}

function members(entry: TypeDocReflection) {
  const seen = new Set<string>();
  const merged = [
    ...(entry.children ?? []),
    ...collectMembersFromType(entry.type),
  ].filter((member) => {
    if (seen.has(member.name)) {
      return false;
    }
    seen.add(member.name);
    return true;
  });

  return merged;
}

function functionSignatures(entry: TypeDocReflection) {
  return entry.signatures ?? [];
}

function entriesFor(names: string[]) {
  return names
    .map((name) => byName.get(name))
    .filter(Boolean) as TypeDocReflection[];
}

const sidebarLinks = renderedGroups.map((group) => ({
  href: `#${group.id}`,
  label: group.label,
}));
---

<Base title="API" description="Generated TypeDoc reference for the public vitest-evals root API.">
  <DocsPageShell links={sidebarLinks}>
    <p class="eyebrow">Reference</p>
    <h1 class="api-title">Public API</h1>
    <p class="lead api-lead">
      Generated from source JSDoc and TypeDoc metadata for the public
      <code>vitest-evals</code> root exports. Use the grouped sections below
      for signatures, examples, parameters, overloads, and member
      documentation.
    </p>

    {
      renderedGroups.map((group) => (
        <section class="api-group" id={group.id}>
          <h2>{group.label}</h2>
          {entriesFor(group.names).map((entry) => {
            const memberRows = members(entry);
            const entryComment = primaryComment(entry);
            const entryExamples = examples(entry);
            const callSignatures = functionSignatures(entry);

            return (
              <section class="api-entry" id={slug(entry.name)}>
                <div class="api-entry-heading">
                  <h3>
                    <code>{entry.name}</code>
                  </h3>
                  <span>{declarationKind(entry)}</span>
                </div>
                {commentHtml(entryComment) && (
                  <p class="api-summary" set:html={commentHtml(entryComment)} />
                )}
                <div class="api-signature">
                  <Code
                    code={declarationCode(entry)}
                    lang="ts"
                    theme="vitesse-black"
                    wrap={true}
                  />
                </div>
                {callSignatures.length > 0 && (
                  <div class="api-call-signatures">
                    {callSignatures.map((signature, index) => {
                      const params = signature.parameters ?? [];
                      const hasMultipleOverloads = callSignatures.length > 1;

                      return (
                        <div class="api-call-section">
                          {hasMultipleOverloads && (
                            <p class="api-overload-label">
                              Overload {index + 1}
                            </p>
                          )}
                          {params.length > 0 && (
                            <div class="api-params">
                              <p>Parameters</p>
                              {params.map((param) => (
                                <div class="api-param">
                                  <div class="api-param-head">
                                    <code>{parameterName(param)}</code>
                                    {param.defaultValue && (
                                      <span>default {param.defaultValue}</span>
                                    )}
                                  </div>
                                  <div class="api-type-line">
                                    <span>Type</span>
                                    <code>{typeToString(param.type)}</code>
                                  </div>
                                  {commentHtml(param.comment) && (
                                    <p
                                      class="api-param-summary"
                                      set:html={commentHtml(param.comment)}
                                    />
                                  )}
                                </div>
                              ))}
                            </div>
                          )}
                          <div class="api-return">
                            <p>Returns</p>
                            <div class="api-type-line">
                              <code>{signatureReturn(signature)}</code>
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
                {entryExamples.map((example) => (
                  <div class="api-example">
                    <p>Example</p>
                    <Code
                      code={example}
                      lang="ts"
                      theme="vitesse-black"
                      wrap={true}
                    />
                  </div>
                ))}
                {memberRows.length > 0 && (
                  <div class="api-members-list">
                    <p>Members</p>
                    {memberRows.map((member) => {
                      const memberSummary = commentHtml(member.comment);

                      return (
                        <div class="api-member">
                          <div class="api-member-head">
                            <code>
                              {member.name}
                              {member.flags?.isOptional ? "?" : ""}
                            </code>
                            <div class="api-type-line">
                              <span>Type</span>
                              <code>{typeToString(member.type)}</code>
                            </div>
                          </div>
                          {memberSummary && (
                            <p
                              class="api-member-summary"
                              set:html={memberSummary}
                            />
                          )}
                        </div>
                      );
                    })}
                  </div>
                )}
              </section>
            );
          })}
        </section>
      ))
    }
  </DocsPageShell>
</Base>
