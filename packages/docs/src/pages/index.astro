---
import Base from "../layouts/Base.astro";
import PackageManagerTabs from "../components/PackageManagerTabs.astro";
import ReportPreview from "../components/ReportPreview.astro";
import Terminal from "../components/Terminal.astro";
import { PACKAGE_VERSION, VITEST_EVALS_ACTION } from "../utils/version";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const evalExample = `import { expect } from "vitest";
import { describeEval, toolCalls } from "vitest-evals";
import { piAiHarness } from "@vitest-evals/harness-pi-ai";
import { createRefundAgent } from "../src/refundAgent";

describeEval("refund agent", {
  harness: piAiHarness({
    agent: () => createRefundAgent(),
  }),
}, (it) => {
  it("approves a refundable invoice", async ({ run }) => {
    const result = await run("Refund invoice inv_123");

    expect(result.output).toMatchObject({ status: "approved" });
    expect(toolCalls(result.session).map((call) => call.name)).toEqual([
      "lookupInvoice",
      "createRefund",
    ]);
  });
});`;

const actionExample = `- name: Run evals
  run: |
    pnpm exec vitest run --config vitest.evals.config.ts \\
      --reporter=vitest-evals/reporter \\
      --reporter=json \\
      --outputFile.json=vitest-results.json

- uses: ${VITEST_EVALS_ACTION}
  if: always()
  with:
    results: vitest-results.json`;
---

<Base title="Home">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Current package: {PACKAGE_VERSION}</p>
      <h1>AI evals that feel like Vitest.</h1>
      <p>
        Write explicit eval tests, run your real agent or app once, assert on typed
        output, and keep normalized session data for judges, replay, terminal
        output, and GitHub Actions.
      </p>
      <div class="hero-actions">
        <a href={`${base}/docs`} class="btn btn-primary">Guide</a>
        <a href={`${base}/api`} class="btn">API Reference</a>
      </div>
    </div>
    <ReportPreview />
  </section>

  <section class="section">
    <h2>Start Where You Are</h2>
    <p>
      The docs are split by task: set up a project, adapt a runtime, wire CI,
      or inspect the generated API surface.
    </p>
    <div class="path-grid">
      <a class="path-item" href={`${base}/docs#install`}>
        <span>01</span>
        <strong>Set up evals</strong>
        <em>Install packages and create an eval-only Vitest config.</em>
      </a>
      <a class="path-item" href={`${base}/docs#harness-setup`}>
        <span>02</span>
        <strong>Choose a harness</strong>
        <em>Adapt AI SDK, OpenAI Agents, pi-ai, or a custom app flow.</em>
      </a>
      <a class="path-item" href={`${base}/docs#github`}>
        <span>03</span>
        <strong>Publish reports</strong>
        <em>Use the GitHub Action with Vitest JSON artifacts.</em>
      </a>
      <a class="path-item" href={`${base}/api#core-api`}>
        <span>04</span>
        <strong>Look up APIs</strong>
        <em>Scan the common exports before the full generated reference.</em>
      </a>
    </div>
  </section>

  <section class="section">
    <h2>Install</h2>
    <p>
      Install the core package, then add the harness package for the runtime you
      want to test.
    </p>
    <PackageManagerTabs
      npm={`npm install -D vitest-evals
npm install -D @vitest-evals/harness-ai-sdk`}
      pnpm={`pnpm add -D vitest-evals
pnpm add -D @vitest-evals/harness-ai-sdk`}
      bun={`bun add -d vitest-evals
bun add -d @vitest-evals/harness-ai-sdk`}
    />
  </section>

  <section class="section">
    <h2>The Core Loop</h2>
    <div class="grid">
      <div class="card">
        <h3>Bind a harness</h3>
        <p>
          The suite owns one harness. It adapts your agent or app into a
          normalized <code>HarnessRun</code>.
        </p>
      </div>
      <div class="card">
        <h3>Call <code>run(input)</code></h3>
        <p>
          Each test decides when execution happens, then asserts with normal
          Vitest expectations.
        </p>
      </div>
      <div class="card">
        <h3>Judge the same run</h3>
        <p>
          Built-in and custom judges read output, session, tool calls, usage,
          and metadata without re-running the app.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Example</h2>
    <Terminal title="refund.eval.ts" code={evalExample} lang="ts" />
  </section>

  <section class="section">
    <h2>GitHub Actions</h2>
    <p>
      The action reads Vitest JSON reports and publishes summaries, workflow
      annotations, and optional Check Runs.
    </p>
    <Terminal title=".github/workflows/evals.yml" code={actionExample} lang="yaml" />
  </section>
</Base>
