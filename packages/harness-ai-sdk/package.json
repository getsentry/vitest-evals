{
  "name": "@vitest-evals/harness-ai-sdk",
  "version": "0.9.0",
  "description": "AI SDK harness adapter for vitest-evals.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/vitest-evals.git",
    "directory": "packages/harness-ai-sdk"
  },
  "author": "David Cramer",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/getsentry/vitest-evals/issues"
  },
  "homepage": "https://github.com/getsentry/vitest-evals/tree/main/packages/harness-ai-sdk#readme",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts"
  },
  "peerDependencies": {
    "ai": ">=4 <7",
    "vitest-evals": "*"
  },
  "devDependencies": {
    "ai": "^6.0.141",
    "vitest-evals": "workspace:*"
  }
}
