      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts"
  },
  "peerDependencies": {
    "vitest": ">=4 <5"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
