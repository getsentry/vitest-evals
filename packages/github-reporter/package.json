{
  "name": "@vitest-evals/github-reporter",
  "version": "0.9.0-beta.4",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "bin": {
    "vitest-evals-github-report": "./dist/cli.js"
  },
  "files": ["dist"],
  "publishConfig": {
