{
  "name": "@vitest-evals/report-ui",
  "version": "0.12.0",
  "description": "Local React report UI for vitest-evals JSON artifacts.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/vitest-evals.git",
    "directory": "packages/report-ui"
  },
  "author": "David Cramer",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/getsentry/vitest-evals/issues"
  },
  "homepage": "https://github.com/getsentry/vitest-evals/tree/main/packages/report-ui#readme",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts && vite build",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "visual:fixture": "pnpm run build && node ./dist/cli.js ./fixtures/vitest-results.visual.json --workspace /repo"
  },
  "dependencies": {
    "@vitest-evals/core": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
